{
  "version": "2026.07.22-v7",
  "targetClientId": "codex",
  "appearanceMode": "dark",
  "artwork": {
    "globalBackground": null,
    "homeArtwork": null,
    "homeArtworkRatio": "3:1"
  },
  "copy": {
    "homeTitle": null
  },
  "surfaces": {
    "page": "transparent",
    "conversationRoot": "transparent",
    "globalBackgroundOwner": "single-fixed-layer",
    "threadFooter": "edge-fade-to-transparent",
    "sidebar": "translucent",
    "composer": "opaque-contrast-safe",
    "cards": "opaque-contrast-safe",
    "rightPanel": "local-opaque-contrast-safe",
    "overlays": "opaque-contrast-safe"
  },
  "textSurfacePolicy": {
    "resolveInkAgainst": "effective-painted-surface",
    "plainTextBackground": "none",
    "structuralBackdropOnly": true
  },
  "interaction": {
    "decorativePointerEvents": "none",
    "preserveNativeGeometry": true,
    "preserveRightPanelInput": true,
    "lockSemanticUtilitiesToAppearance": true,
    "modelPicker": {
      "levels": ["closed-trigger", "category-menu", "model-submenu", "reasoning-submenu", "speed-submenu"],
      "states": ["hover", "focus", "selected", "checked", "disabled"],
      "parts": ["label", "icon", "badge", "price", "checkmark", "separator"]
    },
    "actionControls": {
      "send": "accent-gradient-with-contrast-ink",
      "stop": "danger-surface-with-running-ring",
      "preserveNativeIconAndHitTarget": true,
      "states": ["idle", "hover", "focus", "pressed", "running", "disabled", "reduced-motion"]
    }
  },
  "requiredStates": ["selected", "hover", "focus", "disabled", "warning", "error"]
}
