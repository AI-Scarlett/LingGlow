{
  "version": "2026.07.23-v8",
  "clientId": "workbuddy",
  "selectorPolicy": {
    "prefer": ["semantic page roots", "ARIA roles", "native state attributes"],
    "avoid": ["duplicated background images", "blanket text recoloring", "per-text backgrounds", "mascot overlay frames", "global z-index promotion"]
  },
  "layerPolicy": {
    "globalBackground": {"position": "fixed", "pointerEvents": "none"},
    "historyAndComposer": {"backgroundImage": "none", "revealGlobalBackground": true, "pageSurface": "transparent", "assistantProseSurface": "none", "localSurfaceOpacityMax": 0.66},
    "cardsAndPopovers": {"opaqueContrastSafe": true, "normalizeNestedPaintedSurfaces": true, "nestedSurfaceMode": "match-explicit-skin-mode", "knownAccountSections": ["check-in", "plan", "credits", "actions"]},
    "customMascot": {
      "replaceInPlace": true,
      "containerTransparent": true,
      "preserveClickTarget": true,
      "fit": "contain",
      "shape": "square",
      "forbid": ["background-crop", "hero-crop", "circle-crop", "frame", "halo", "shadow", "duplicate-overlay"],
      "verifyRoutes": ["new-task", "historical-task"],
      "invalidBehavior": "remove-custom-marker-and-use-native-default-robot"
    },
    "teamMemberEdges": {"fullWidthTopFade": "none", "lateralEdgesUseEffectiveSurface": true, "fadeToTransparent": true, "forbidFullWidthDarkStrip": true},
    "composerSelectors": {"localTranslucentSurface": true, "coverStates": ["closed", "hover", "focus", "expanded"], "popupOpaqueContrastSafe": true},
    "automationEmptyState": {"structuralWrappersTransparent": true, "templateCardsLocalSurface": true, "forbidWholePagePanel": true}
  },
  "appearancePolicy": {"source": "explicit-skin-mode", "lockNativeMode": true, "resolveInkAgainst": "effective-painted-surface"},
  "textSurfacePolicy": {"plainTextBackground": "none", "paintStructuralParent": true, "nestedComposerEditorBackground": "transparent", "nestedPopupSurfaceBackground": "semantic-surface-elevated", "resolvePopupInkAgainstClosestPaintedAncestor": true, "preserveControls": true}
}
