{
  "version": "2026.07.20-v4",
  "clientId": "doubao",
  "selectorPolicy": {
    "prefer": ["data-testid", "ARIA roles", "native selected and focus states"],
    "avoid": ["blanket content transparency", "forcing all text to accent color", "per-text backgrounds", "interactive overlays"]
  },
  "layerPolicy": {
    "globalBackground": {"position": "fixed", "pointerEvents": "none"},
    "chatCanvas": {"removeOpaqueVeil": true, "preserveReadableMessages": true},
    "composer": {"preserveInputAndToolClicks": true}
  },
  "appearancePolicy": {"source": "explicit-skin-mode", "lockNativeMode": true, "resolveInkAgainst": "effective-painted-surface"},
  "textSurfacePolicy": {"plainTextBackground": "none", "paintStructuralParent": true, "preserveControls": true}
}
